# Padho Label environment variables
# Copy this file to ".env" and fill in your own values. NEVER commit ".env".
# All values are OPTIONAL — with none set, the app is a fully working
# Open Food Facts + OCR scanner. These just add depth.

# ── Curated catalog (Airtable) ──────────────────────────────────────────────
# Looked up FIRST on every scan, before Open Food Facts — authoritative data
# for the D2C brands and new/limited-edition SKUs you care about.
# Base: "Padho Label" → table "Products".
# SECURITY: use a READ-ONLY Personal Access Token scoped to THIS BASE ONLY
# (scope: data.records:read). It is bundled into the app, so never use a broad
# token. Create one at https://airtable.com/create/tokens
EXPO_PUBLIC_AIRTABLE_BASE_ID=appdFbiM5AogN1muz
EXPO_PUBLIC_AIRTABLE_TOKEN=YOUR_READONLY_BASE_SCOPED_TOKEN
EXPO_PUBLIC_AIRTABLE_TABLE=Products

# ── Label OCR (OCR.space) ───────────────────────────────────────────────────
# Enables the "scan the ingredients label" fallback for products not found by
# barcode. Free key (25,000 req/month) at https://ocr.space/ocrapi
# If unset, falls back to the rate-limited "helloworld" demo key.
EXPO_PUBLIC_OCRSPACE_API_KEY=YOUR_OCRSPACE_API_KEY_HERE
